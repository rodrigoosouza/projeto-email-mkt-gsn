# ============================================
# PLATAFORMA DE EMAIL MARKETING
# Copie este arquivo para .env.local e preencha
# ============================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:senha@db.seu-projeto.supabase.co:5432/postgres

# --- MAILERSEND ---
# API key principal (ou usar por organização via DB)
MAILERSEND_API_KEY=mlsn.xxx
MAILERSEND_WEBHOOK_SECRET=seu-webhook-secret

# --- WHATSAPP CLOUD API (Meta) ---
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789
WHATSAPP_VERIFY_TOKEN=token-verificacao-webhook
WHATSAPP_APP_SECRET=secret-para-validar-assinatura

# --- GOOGLE ANALYTICS ---
# Service account JSON (path ou inline)
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
# Ou inline:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# --- META ADS API ---
META_ADS_ACCESS_TOKEN=EAAx...
META_ADS_APP_SECRET=secret

# --- GOOGLE ADS API ---
GOOGLE_ADS_DEVELOPER_TOKEN=xxx
GOOGLE_ADS_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=xxx
GOOGLE_ADS_REFRESH_TOKEN=xxx

# --- N8N ---
N8N_BASE_URL=https://seu-n8n.com
N8N_API_KEY=n8n-api-key
N8N_WEBHOOK_BASE_URL=https://seu-n8n.com/webhook

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Plataforma Email
NODE_ENV=development

# --- SEGURANÇA ---
# Chave para encriptar dados sensíveis (gerar com: openssl rand -hex 32)
ENCRYPTION_KEY=gerar-chave-de-32-bytes-hex

# --- SMS (Fase 4) ---
# TWILIO_ACCOUNT_SID=xxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+55xxx
# Ou Zenvia:
# ZENVIA_API_TOKEN=xxx
